# ──────────────────────────────────────────────────────────────────────────────
# VPNinABox configuration template
# Copy to .env and fill in real values:
#   cp .env.example .env
#
# NEVER commit .env to git — it contains secrets.
# ──────────────────────────────────────────────────────────────────────────────

# Proxmox host
PROXMOX_HOST=192.168.1.185
PROXMOX_PASSWORD=your_proxmox_root_password

# NordVPN Personal Access Token (PAT)
# Get from: https://nordvpn.com/en/user/nordaccount-settings/tokens
# Use a PAT — NOT the device token from "nordvpn token".
# Device tokens cannot register a new meshnet node on a different machine.
NORDVPN_TOKEN=your_nordvpn_personal_access_token

# Network shared by all nodes
GATEWAY=192.168.1.1
SUBNET=192.168.1.0/24

# ── Node definitions ──────────────────────────────────────────────────────────
# Define each NordVPN exit node with a NODE_n_ prefix.
# Required: NODE_n_VMID, NODE_n_IP, NODE_n_COUNTRY
# Optional: NODE_n_HOSTNAME (defaults to nordvpn-<country_lowercase>)
#
# Add more NODE_3_*, NODE_4_* blocks for additional exit nodes.

NODE_1_VMID=200
NODE_1_IP=192.168.1.50
NODE_1_COUNTRY=Taiwan
NODE_1_HOSTNAME=nordvpn-taiwan

NODE_2_VMID=201
NODE_2_IP=192.168.1.51
NODE_2_COUNTRY=US
NODE_2_HOSTNAME=nordvpn-us

# ── OpenWRT router ────────────────────────────────────────────────────────────
# Required by openwrt-switch-lan-ip-to-nordvpn-gw.sh
OPENWRT_HOST=192.168.1.1
OPENWRT_PASSWORD=your_openwrt_root_password
OPENWRT_SSH_PORT=22   # default 22; change if Dropbear runs on a different port
